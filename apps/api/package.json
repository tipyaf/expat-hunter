{
  "name": "@expat-hunter/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "NODE_OPTIONS='--import tsx/esm' node ace serve --hmr",
    "build": "node --import tsx/esm ace build",
    "start": "node bin/server.js",
    "lint": "eslint .",
    "test": "NODE_ENV=test node --import tsx/esm bin/test.ts",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#ai/*": "./app/ai/*.js",
    "#constants/*": "./app/constants/*.js",
    "#scrapers/*": "./app/scrapers/*.js",
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": [
      "./app/policies/*.js"
    ],
    "#abilities/*": "./app/abilities/*.js",
    "#config/*": "./config/*.js",
    "#start/*": "./start/*.js",
    "#migrations/*": "./database/migrations/*.js",
    "#seeders/*": "./database/seeders/*.js",
    "#factories/*": "./database/factories/*.js",
    "#tests/*": "./tests/*.js"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.1.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/i18n": "^3.0.0",
    "@adonisjs/lucid": "^22.1.1",
    "@adonisjs/mail": "^10.0.1",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@expat-hunter/shared": "workspace:^",
    "@poppinss/ts-exec": "^1.4.4",
    "@vinejs/vine": "^4.3.0",
    "bcrypt": "^6.0.0",
    "disposable-email-domains": "^1.0.62",
    "hot-hook": "^1.0.0",
    "ioredis": "^5.10.1",
    "luxon": "^3.7.2",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^8.0.4",
    "pdf-parse": "1.1.1",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "youch": "4"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.1.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@swc/core": "^1.15.18",
    "@types/bcrypt": "^6.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5"
  }
}
