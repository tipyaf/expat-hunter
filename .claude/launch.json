{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "apps/frontend",
      "autoPort": true
    },
    {
      "name": "wireframes",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8090", "-d", "specs/wireframes"],
      "port": 8090
    },
    {
      "name": "ux-wireframes",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "_work/ux/wireframes", "-l", "8091", "--no-clipboard"],
      "port": 8091
    }
  ]
}
