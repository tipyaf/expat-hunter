# ============================================================================
# ExpatHunter — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#
# SECURITY: All passwords and secrets below are left empty on purpose.
# For production, generate unique values — NEVER reuse defaults from git history.
#   openssl rand -base64 32    (for APP_KEY, passwords)
# ============================================================================

# --- App ---
NODE_ENV=development
APP_KEY=
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (PostgreSQL) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# --- Redis (Queue broker) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
TOKEN_EXPIRY=7days

# --- Mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- OpenRouter (AI) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Frontend ---
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# --- Sonar (Code quality) ---
SONAR_TOKEN=
SONAR_HOST_URL=http://localhost:9000
SONAR_PROJECT_KEY=expathunter
SONAR_BASE_BRANCH=origin/main

# --- SonarQube Docker (local dev) ---
SONAR_JDBC_URL=jdbc:postgresql://db:5432/sonar
SONAR_JDBC_USERNAME=
SONAR_JDBC_PASSWORD=

# --- File uploads ---
DRIVE_DISK=local
UPLOAD_MAX_SIZE=10mb
