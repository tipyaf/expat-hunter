# ============================================================================
# ExpatHunter — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values
# ============================================================================

# --- App ---
NODE_ENV=development
APP_KEY=generate-a-random-32-char-string
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (PostgreSQL) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=expathunter
DB_PASSWORD=expathunter
DB_DATABASE=expat_hunter_dev

# --- Redis (Queue broker) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
TOKEN_EXPIRY=7days

# --- Mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- OpenRouter (AI) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Frontend ---
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# --- File uploads ---
DRIVE_DISK=local
UPLOAD_MAX_SIZE=10mb
