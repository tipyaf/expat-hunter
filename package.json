{
  "name": "expat-hunter",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:all": "docker compose --env-file .env -f .devtools/docker-compose.yml --profile sonar up -d && pnpm dev",
    "db:up": "docker compose --env-file .env -f .devtools/docker-compose.yml up -d",
    "db:down": "docker compose --env-file .env -f .devtools/docker-compose.yml down",
    "sonar:up": "docker compose --env-file .env -f .devtools/docker-compose.yml --profile sonar up -d",
    "sonar:down": "docker compose --env-file .env -f .devtools/docker-compose.yml --profile sonar down",
    "dev:api": "pnpm --filter @expat-hunter/api dev",
    "dev:frontend": "pnpm --filter @expat-hunter/frontend dev",
    "build": "pnpm --filter @expat-hunter/shared build && pnpm --parallel --filter './apps/*' build",
    "build:api": "pnpm --filter @expat-hunter/api build",
    "build:frontend": "pnpm --filter @expat-hunter/frontend build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm --parallel --filter './apps/*' test",
    "test:api": "pnpm --filter @expat-hunter/api test",
    "test:frontend": "pnpm --filter @expat-hunter/frontend test",
    "test:e2e": "pnpm --filter @expat-hunter/e2e test",
    "db:migrate": "pnpm --filter @expat-hunter/api db:migrate",
    "db:seed": "pnpm --filter @expat-hunter/api db:seed",
    "db:reset": "pnpm --filter @expat-hunter/api db:reset"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
